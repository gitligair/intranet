{% extends 'base.html.twig' %}

{% block title %}Connexion
{% endblock %}

{% block body %}

	<style>
		body {
			margin: 0 !important;
			padding: 0 !important;
			overflow: hidden;
			font-family: 'Inter', sans-serif;
			background: linear-gradient(135deg, #0E3B64, #6ED6FF);
		}

		.glass-wrapper {
			position: fixed;
			inset: 0;
			display: flex;
			flex-direction: column;
			justify-content: center;
			align-items: center;
			padding: 20px;
		}

		.glass-card {
			max-width: 500px;
			padding: 2.8rem 2.5rem;
			border-radius: 18px;
			backdrop-filter: blur(18px);
			background: rgba(255, 255, 255, 0.14);
			border: 1px solid rgba(255, 255, 255, 0.22);
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
			color: #fff;
			animation: fadeIn 0.6s ease-out;
			text-align: center;
		}

		.glass-logo {
			width: 120px;
			height: auto;
			margin-bottom: 1rem;
			filter: drop-shadow(0 3px 6px rgba(0,0,0,0.3));
		}

		.glass-title-main {
			font-size: 1.45rem;
			font-weight: 600;
			margin-bottom: 1.8rem;
			text-transform: uppercase;
			letter-spacing: 0.7px;
			color: #dff8ff;
		}

		/* Input group */
		.input-group {
			position: relative;
			margin-bottom: 1rem;
		}

		.input-icon {
			position: absolute;
			left: 12px;
			top: 50%;
			transform: translateY(-50%);
			opacity: 0.9;
			font-size: 18px;
			pointer-events: none;
			color: #dffaff;
		}

		.form-control {
			width: 100%;
			padding: 0.65rem 0.85rem 0.65rem 2.7rem;
			background: rgba(255, 255, 255, 0.15);
			border: 1px solid rgba(255, 255, 255, 0.3);
			color: #fff;
			border-radius: 8px;
			transition: background 0.2s, border-color 0.2s;
		}

		.form-control:focus {
			background: rgba(255, 255, 255, 0.23);
			border-color: #4CD4CB;
			box-shadow: 0 0 0 0.15rem rgba(76, 212, 203, 0.35);
		}

		.form-control::placeholder {
			color: rgba(255, 255, 255, 0.7);
		}

		/* Eye button */
		.password-toggle {
			position: absolute;
			right: 12px;
			top: 50%;
			transform: translateY(-50%);
			cursor: pointer;
			opacity: 0.85;
			font-size: 18px;
			color: #dffaff;
		}

		/* Button turquoise */
		.btn-glass {
			width: 100%;
			padding: 0.7rem;
			margin-top: 0.5rem;
			background: linear-gradient(135deg, #4CD4CB, #6ED6FF);
			border: none;
			border-radius: 10px;
			color: #00324f;
			font-weight: 700;
			letter-spacing: 0.4px;
			transition: 0.15s;
		}

		.btn-glass:hover {
			transform: translateY(-2px);
			box-shadow: 0 6px 14px rgba(0, 140, 200, 0.35);
		}

		/* Footer */
		.login-footer {
			margin-top: 16px;
			text-align: center;
			color: #e6faff;
			font-size: 0.85rem;
			opacity: 0.85;
		}

		@keyframes fadeIn {
			from {
				opacity: 0;
				transform: translateY(12px);
			}
			to {
				opacity: 1;
				transform: translateY(0);
			}
		}
	</style>


	<div class="glass-wrapper">
		<div class="glass-card">

			<img src="{{ asset('images/logo-ligair.png') }}" alt="LIGAIR" class="glass-logo">

			<div class="glass-title-main">Portail d'administration LIGAIR</div>

			{% if error %}
				<div class="alert alert-danger">
					{{ error.messageKey|trans(error.messageData, 'security') }}
				</div>
			{% endif %}

			{% if app.user %}
				<div class="alert alert-info small">
					Vous êtes connecté en tant que
					<strong>{{ app.user.userIdentifier }}</strong>,
					<a href="{{ path('app_logout') }}">Déconnexion</a>
				</div>
			{% endif %}

			<form
				method="post">

				<!-- Email -->
				<div class="input-group">
					<span class="input-icon">📧</span>
					<input type="email" value="{{ last_username }}" name="_username" id="username" class="form-control" placeholder="Adresse email" required autofocus>
				</div>

				<!-- Password -->
				<div class="input-group">
					<span class="input-icon">🔒</span>
					<input type="password" name="_password" id="password" class="form-control" placeholder="Mot de passe" required>
					<span class="password-toggle" id="togglePassword">👁️</span>
				</div>

				<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

				<button class="btn-glass" type="submit">Se connecter</button>
			</form>
		</div>

		<div class="login-footer">
			©
			{{ "now"|date("Y") }}
			— LIGAIR • Portail Administratif
		</div>
	</div>


	<script>
		document.getElementById('togglePassword').addEventListener('click', function () {
const pwd = document.getElementById('password');
if (pwd.type === "password") {
pwd.type = "text";
this.textContent = "🙈";
} else {
pwd.type = "password";
this.textContent = "👁️";
}
});
	</script>

{% endblock %}
